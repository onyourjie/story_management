{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "TS_NODE_TRANSPILE_ONLY=true node -r ts-node/register src/index.ts",
    "dev": "TS_NODE_TRANSPILE_ONLY=true nodemon --exec ts-node src/index.ts",
    "build": "prisma generate && tsc",
    "postinstall": "prisma generate",
    "test": "jest --forceExit --runInBand",
    "test:coverage": "jest --coverage --forceExit --runInBand",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:seed": "ts-node src/prisma/seed.ts"
  },
